---
import { getEntry } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
const siteSettings = await getEntry('settings', 'site');
const globalTitle = siteSettings?.data.siteTitle || '品牌網站';
const finalTitle = `${title} | ${globalTitle}`;
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="個人花藝品牌網站" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{finalTitle}</title>
	</head>
	<body class="bg-[#fdfaf6] text-[#4a4a4a] font-sans min-h-screen flex flex-col relative overflow-x-hidden">
        <div class="fixed inset-0 z-0 pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-[#fce4ec] opacity-60 blur-[100px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[60%] h-[60%] rounded-full bg-[#e8f5e9] opacity-60 blur-[100px]"></div>
            <div class="absolute top-[20%] right-[10%] w-[30%] h-[30%] rounded-full bg-[#fff9c4] opacity-40 blur-[80px]"></div>
        </div>
        <Header />
		<main class="relative z-10 flex-grow pt-24 pb-12 w-full max-w-full overflow-hidden">
			<slot />
		</main>
        <Footer />
	</body>
</html>
