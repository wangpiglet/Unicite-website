---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const siteSettings = await getEntry('settings', 'site');
const { heroImage, heroTitle, heroSubtitle } = siteSettings.data;
---

<Layout title="首頁">
    <section class="max-w-6xl mx-auto px-4 py-8 md:py-12 flex flex-col md:flex-row gap-8 items-stretch">
        <div class="flex-1 backdrop-blur-xl bg-white/40 rounded-[32px] p-10 md:p-16 border border-white/60 shadow-xl flex flex-col justify-center">
            <div class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.3em] mb-4">Site Settings / Hero</div>
            <h1 class="text-5xl md:text-6xl font-serif italic leading-[1.1] mb-6 text-[#2c3e50] drop-shadow-sm">{heroTitle}</h1>
            <p class="text-lg md:text-xl leading-relaxed text-[#5d6d7e] mb-10 font-light max-w-lg">{heroSubtitle}</p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/courses" class="bg-[#7d8c72] text-white px-8 py-4 rounded-full text-sm font-bold uppercase tracking-widest w-fit shadow-lg shadow-[#7d8c72]/30 hover:bg-[#6c7962] transition text-center">探索課程</a>
                <a href="/portfolio" class="px-8 py-4 rounded-full border border-[#7d8c72] text-[#7d8c72] bg-white/50 text-sm font-bold uppercase tracking-widest w-fit hover:bg-[#7d8c72] hover:text-white transition text-center shadow-sm">查看作品</a>
            </div>
        </div>
        <div class="flex-1">
            <div class="w-full h-[400px] md:h-full min-h-[400px] rounded-[32px] overflow-hidden border-8 border-white/60 shadow-xl relative backdrop-blur-md bg-white/20">
                <img src={heroImage} alt="Hero" class="absolute inset-0 w-full h-full object-cover" />
            </div>
        </div>
    </section>
</Layout>
