---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const courses = await getCollection('courses');
---

<Layout title="課程介紹">
    <section class="max-w-6xl mx-auto px-4 py-12">
        <div class="text-center mb-12">
            <div class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.3em] mb-4">Collection: Courses</div>
            <h1 class="text-4xl md:text-5xl font-serif italic text-[#2c3e50] drop-shadow-sm">精選花藝課程</h1>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {courses.map(course => (
                <a href={`/courses/${course.slug}`} class="group backdrop-blur-xl bg-white/40 rounded-[32px] overflow-hidden border border-white/60 shadow-xl flex flex-col transition duration-300 hover:shadow-2xl hover:bg-white/50">
                    <div class="aspect-[4/3] overflow-hidden m-4 rounded-[24px] relative border-2 border-white/50">
                        <img src={course.data.coverImage} alt={course.data.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-700" />
                    </div>
                    <div class="p-6 pt-2 flex-grow flex flex-col">
                        <h2 class="text-xl font-serif italic text-[#2c3e50] mb-2">{course.data.title}</h2>
                        <p class="text-[#5d6d7e] mb-6 line-clamp-2 text-sm flex-grow font-light">{course.data.description}</p>
                        <div class="flex justify-between items-center bg-white/50 rounded-2xl p-4 border border-white/40 mt-auto shadow-sm">
                            <div class="flex flex-col">
                                <span class="text-[10px] text-gray-500 uppercase tracking-widest leading-tight">{course.data.duration}</span>
                            </div>
                            <div class="flex flex-col items-end">
                                <span class="text-lg font-serif italic text-[#2c3e50] leading-tight">NT$ {course.data.price?.toLocaleString()}</span>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </section>
</Layout>
