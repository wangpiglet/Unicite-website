---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const contactData = await getEntry('contact', 'index');
const { instagram, line, email, contactText } = contactData.data;
const { Content } = await contactData.render();
---

<Layout title="聯絡我">
    <section class="max-w-5xl mx-auto px-4 py-12 grid md:grid-cols-12 gap-8">
        <div class="md:col-span-5 backdrop-blur-xl bg-white/40 rounded-[32px] p-10 border border-white/60 shadow-xl flex flex-col justify-center text-center">
            <div class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.3em] mb-4">Collection: Contact</div>
            <h1 class="text-5xl font-serif italic text-[#2c3e50] mb-6 drop-shadow-sm">聯絡我</h1>
            <p class="text-lg text-[#5d6d7e] font-light leading-relaxed">{contactText}</p>
        </div>
        
        <div class="md:col-span-7 backdrop-blur-xl bg-white/40 rounded-[32px] p-10 border border-white/60 shadow-xl">
            <h2 class="text-2xl font-serif italic text-[#2c3e50] mb-8 pb-4 border-b border-white/40 drop-shadow-sm">透過以下方式聯繫</h2>
            
            <div class="flex flex-col gap-4">
                {email && (
                    <div class="flex items-center justify-between p-4 bg-white/50 rounded-2xl border border-white/40 shadow-sm">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.2em] mb-1">Email</span>
                            <a href={`mailto:${email}`} class="text-lg font-medium text-[#2c3e50] hover:text-[#7d8c72] transition">{email}</a>
                        </div>
                        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-[#7d8c72] shadow-sm border border-white/60">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        </div>
                    </div>
                )}
                
                {line && (
                    <div class="flex items-center justify-between p-4 bg-white/50 rounded-2xl border border-white/40 shadow-sm">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.2em] mb-1">LINE 官方帳號</span>
                            <a href="#" class="text-lg font-medium text-[#2c3e50] hover:text-[#7d8c72] transition">{line}</a>
                        </div>
                        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-[#7d8c72] shadow-sm border border-white/60">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                        </div>
                    </div>
                )}

                {instagram && (
                    <div class="flex items-center justify-between p-4 bg-white/50 rounded-2xl border border-white/40 shadow-sm">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.2em] mb-1">Instagram</span>
                            <a href={instagram} target="_blank" rel="noopener noreferrer" class="text-lg font-medium text-[#2c3e50] hover:text-[#7d8c72] transition">@floral_artist</a>
                        </div>
                        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-[#7d8c72] shadow-sm border border-white/60">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                        </div>
                    </div>
                )}
            </div>

            <div class="mt-10 text-center text-[#5d6d7e] font-light prose prose-lg max-w-none pt-8 border-t border-white/40">
                <Content />
            </div>
        </div>
    </section>
</Layout>
