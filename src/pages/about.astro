---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const aboutData = await getEntry('about', 'index');
const { title, profileImage } = aboutData.data;
const { Content } = await aboutData.render();
---

<Layout title={title}>
    <section class="max-w-5xl mx-auto px-4 py-12">
        <div class="backdrop-blur-xl bg-white/40 rounded-[32px] p-8 md:p-12 border border-white/60 shadow-xl flex flex-col md:flex-row gap-12 items-center">
            <div class="w-full md:w-5/12">
                <div class="rounded-[32px] overflow-hidden border-8 border-white/60 shadow-xl relative aspect-[4/5] bg-white/20">
                    <img src={profileImage} alt={title} class="absolute inset-0 w-full h-full object-cover" />
                </div>
            </div>
            <div class="w-full md:w-7/12">
                <div class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.3em] mb-4">Collection: About</div>
                <h1 class="text-4xl md:text-5xl font-serif italic text-[#2c3e50] mb-8 pb-4 border-b border-white/40">{title}</h1>
                <div class="prose prose-lg text-[#5d6d7e] font-light leading-relaxed max-w-none">
                    <Content />
                </div>
            </div>
        </div>
    </section>
</Layout>
