---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const portfolios = await getCollection('portfolio');

// Color mapping for cards similar to Frosted Glass look
const colors = ['bg-[#d9a5a5]', 'bg-[#a5bdc9]', 'bg-[#7d8c72]', 'bg-[#eec69f]', 'bg-[#bcaaa4]'];
---

<Layout title="作品集">
    <section class="max-w-6xl mx-auto px-4 py-12">
        <div class="text-center mb-12">
            <div class="text-xs font-bold text-[#7d8c72] uppercase tracking-[0.3em] mb-4">Collection: Portfolio</div>
            <h1 class="text-4xl md:text-5xl font-serif italic text-[#2c3e50] drop-shadow-sm">花藝作品集</h1>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {portfolios.map((item, index) => (
                <a href={`/portfolio/${item.slug}`} class={`group relative block overflow-hidden rounded-[32px] aspect-[4/3] shadow-xl ${colors[index % colors.length]} flex items-end p-6 border border-white/40`}>
                    <img src={item.data.coverImage} alt={item.data.title} class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-60 group-hover:scale-105 group-hover:opacity-80 transition duration-700" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/5 to-transparent border-[6px] border-white/20 rounded-[32px]"></div>
                    <div class="relative z-10 w-full flex flex-col">
                        <span class="text-white font-serif italic text-2xl drop-shadow-md mb-1">{item.data.title}</span>
                        <span class="text-white/80 text-sm font-light line-clamp-1">{item.data.description}</span>
                    </div>
                </a>
            ))}
        </div>
    </section>
</Layout>
